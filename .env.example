# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Enables the clearly labelled local demo path. Never enable in production.
PEPPLY_DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true

# Supabase (PostgreSQL + Auth)
# Uncomment and replace these values when leaving demo mode.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI adapter. The key is read server-side only.
# OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5.6-terra
OPENAI_MODERATION_MODEL=omni-moderation-latest
AI_DAILY_USER_LIMIT=5

# Optional push notifications
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@example.com

# Optional external integrations (adapters are intentionally disabled without keys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
SENTRY_DSN=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
